# Application
PROJECT_NAME=DaCodes AI Service
VERSION=1.0.0
ENVIRONMENT=development

# API
API_V1_PREFIX=/ai/v1
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Security
API_KEY=your-secret-api-key-change-in-production

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/dacodes_inventory
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# Redis
REDIS_URL=redis://localhost:6379/0
CACHE_TTL_FORECAST=86400
CACHE_TTL_SUPPLIER_SCORE=604800
CACHE_TTL_WASTE=43200

# S3 / Object Storage
S3_BUCKET=dacodes-ai-models
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# ML Models
MODEL_PATH=/app/models
ENABLE_GPU=false

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json

# Performance
MAX_WORKERS=4
REQUEST_TIMEOUT=30
