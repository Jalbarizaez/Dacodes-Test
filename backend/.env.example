# Server Configuration
NODE_ENV=development
PORT=3000
API_VERSION=v1

# Database Configuration
# PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
DATABASE_URL=postgres://94919f7c963c93f21be0dbc4dc66e8599f74eb4a171cae00a9f325dc2730cad9:sk_D3oze9hymmMdnGQkNuzTj@db.prisma.io:5432/postgres?sslmode=require

# Frontend URL (for CORS and WebSocket)
# Comma-separated for multiple origins, use * for wildcards
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173,https://*.tunnelmole.net

# Logging
# Levels: error, warn, info, http, debug
LOG_LEVEL=debug

# Features
# Allow negative stock levels (true/false)
ALLOW_NEGATIVE_STOCK=false

# JWT Configuration (for future authentication)
JWT_SECRET=your-secret-key-change-in-production-min-32-chars-required
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d
